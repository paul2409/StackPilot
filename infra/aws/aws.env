# infra/aws/aws.env
#
# Local convenience only.
# CI MUST use environment credentials from GitHub Secrets and should NOT rely on profiles.
#
# IMPORTANT:
# - Do not hard-force AWS_PROFILE in CI paths.
# - Scripts will ignore AWS_PROFILE when AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY are present.

export AWS_PROFILE="${AWS_PROFILE:-stackpilot-ci}"

export AWS_REGION="${AWS_REGION:-us-east-1}"
export AWS_DEFAULT_REGION="${AWS_DEFAULT_REGION:-${AWS_REGION}}"

# default to the ephemeral key generated each run
export SSH_KEY_PATH="${SSH_KEY_PATH:-artifacts/aws/stackpilot_ci_key}"
