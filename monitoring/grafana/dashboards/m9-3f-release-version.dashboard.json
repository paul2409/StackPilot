        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (job) (rate(http_requests_total{status=~\"4..|5..\"}[5m]))",
          "legendFormat": "{{job}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Error Behavior After Rollout",
      "type": "timeseries"
    },
