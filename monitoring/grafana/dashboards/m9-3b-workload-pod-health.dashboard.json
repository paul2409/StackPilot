      "targets": [
        {
          "editorMode": "code",
          "expr": "max by (deployment) (kube_deployment_status_replicas_unavailable{namespace=~\"$namespace\", deployment=~\"identity-service|wallet-service|system-service|customer-portal|admin-portal|ops-portal|postgres-identity|postgres-wallet\"})",
